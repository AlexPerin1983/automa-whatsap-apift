# ProspectLocal
# Este arquivo e apenas uma referencia de configuracao.
# A versao atual do projeto nao carrega .env automaticamente:
# - o token da Apify e salvo pela interface do sistema
# - a sessao do WhatsApp e criada localmente ao conectar o numero
#
# Use este arquivo como checklist do que precisa estar disponivel
# na maquina de quem for rodar o projeto.

# Token da Apify
# Hoje este valor deve ser inserido dentro do painel do ProspectLocal.
APIFY_API_TOKEN=coloque_seu_token_aqui

# URL local esperada pelo servico de WhatsApp
FLASK_BASE_URL=http://localhost:5000

# Porta padrao do servico WhatsApp
WHATSAPP_SERVICE_PORT=3001

# Pasta local onde as sessoes do WhatsApp ficam salvas
WHATSAPP_SESSIONS_DIR=./whatsapp-service/sessions
